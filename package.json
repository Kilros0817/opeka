{
  "name": "vite-html-scss",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "web-types": "./web-types.json",
  "scripts": {
    "gen:web-types": "node scripts/gen-web-types.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:html": "htmlhint \"src/**/*.html\"",
    "lint:js": "eslint \"src/**/*.js\"",
    "lint:contracts": "bash scripts/lint-contracts.sh",
    "lint": "npm run lint:scss && npm run lint:html && npm run lint:js && npm run lint:contracts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.scss": "stylelint --fix",
    "src/**/*.html": "htmlhint",
    "src/**/*.js": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@malobre/vite-plugin-posthtml": "^0.1.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "htmlhint": "^1.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "posthtml-component": "^2.3.0",
    "posthtml-render": "^3.0.0",
    "sass": "^1.77.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "gsap": "^3.15.0"
  }
}
